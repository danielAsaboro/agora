# --- Arc network ---
# Source: ~/.arc-canteen/env after `arc-canteen init`
RPC=
DEPLOYER_PK=
CHAIN_ID=
# Client-side mirrors (these are inlined into the JS bundle by Next.js)
NEXT_PUBLIC_RPC=
NEXT_PUBLIC_CHAIN_ID=
NEXT_PUBLIC_EXPLORER_URL=
NEXT_PUBLIC_WC_PROJECT_ID=

# --- Contract addresses (filled in by `forge script script/Deploy.s.sol`) ---
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_VAULT_FACTORY_ADDRESS=
NEXT_PUBLIC_SLASHING_ARBITER_ADDRESS=
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=

# --- Database (Prisma + Postgres) ---
# Local dev:  postgresql://USER@localhost:5432/agora?schema=public
# Hosted prod: paste the connection URL from Neon/Railway/Vercel-postgres
DATABASE_URL=

# --- Circle (per arc-escrow) ---
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_BLOCKCHAIN=ARC-TESTNET

# --- OpenAI: TradingAgents brain + trace-fraud validator ---
OPENAI_API_KEY=

# --- Irys ---
IRYS_NODE=https://devnet.irys.xyz
IRYS_PRIVATE_KEY=

# --- Polymarket V2 ---
# If Polymarket V2 isn't reachable from Arc testnet, leave POLYMARKET_BASE empty
# and the system uses the MockPredictionMarket adapter (deployed by Deploy.s.sol).
POLYMARKET_BASE=
POLYMARKET_CHAIN_ID=

# --- Optional: pre-built per-Pythia data-source keys ---
APOLLO_FRED_API_KEY=
HERMES_NEWS_API_KEY=
ATHENA_ODDSAPI_KEY=
HEPHAESTUS_GITHUB_TOKEN=

# --- Traction telemetry ---
ARC_CANTEEN_BIN=arc-canteen
